{
  "name": "app-attendance-api",
  "version": "1.0.0",
  "description": "Backend API REST para sistema académico de asistencia con QR temporal",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"Comando no disponible en package.json\"",
    "test": "echo \"Comando no disponible en package.json\""
  },
  "keywords": [
    "attendance",
    "qr",
    "express",
    "typescript",
    "mongodb",
    "mongoose",
    "jwt",
    "zod"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.0",
    "@types/uuid": "^11.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}